# ---- Shared ----
# Shared secret used for X-API-KEY authentication between components
API_KEY=change-me-to-a-strong-secret

# ---- Component B: Logging Server ----
# Port the logging server listens on
PORT=8000

# ---- Component A: Ingestion Bus ----
# Port the ingestion bus listens on
BUS_PORT=8001
# Base URL of the logging server (Component B)
LOG_SERVER_URL=http://localhost:8000
